SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
FIRMS_MAP_KEY=your-firms-map-key
OPENAQ_API_KEY=your-openaq-api-key

# Optional. A webhook URL (e.g. an n8n workflow webhook) that receives a POST
# with {source, subject, body} JSON when a fetch fails or a source goes
# stale. If unset, alerts are logged but not sent.
NOTIFY_WEBHOOK_URL=
